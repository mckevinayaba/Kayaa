VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Web Push (VAPID) — required for safety push notifications
# Generate once:  npx web-push generate-vapid-keys
# Then paste the PUBLIC key here (the private key goes in Supabase Edge Function secrets)
VITE_VAPID_PUBLIC_KEY=

# Groq — for venue description generation (FREE, no credit card, works from SA)
# Get yours at: https://console.groq.com
GROQ_API_KEY=gsk_...
